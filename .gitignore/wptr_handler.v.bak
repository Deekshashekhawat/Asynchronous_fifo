

module wptr_handler#(parameter ptr_width=3)(
input wclk,w_rstn,w_en,
input [ptr_width:0]g_rptr_sync,
output reg full,
output reg [ptr_width:0]b_wptr,
output reg [ptr_width:0]g_wptr
);
 
wire [ptr_width:0]b_wptr_next;
wire [ptr_width:0]g_wptr_next;
wire w_full;

always@(wclk or !w_rstn)begin
if(!w_rstn) begin
b_wptr<=0;
g_wptr<=0;
end
else begin
b_wptr<=b_wptr_next;
g_wptr<=g_wptr_next;
end
end

assign b_wptr_next=b_wptr+(w_en & !full);
assign g_wptr_next=b_wptr_next^(b_wptr_next>>1);

//full logic


assign w_full= (g_wptr_next=={~([ptr_width:(ptr_width-1)]g_rptr_sync),[(ptr_width-2):0]g_rptr_sync});

always @(posedge wclk or negedge w_rstn)begin
if(!w_rstn) full<=0;
else full<=w_full;
end

endmodule